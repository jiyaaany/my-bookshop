# 번잡한 책방 — environment variables
# Copy to `.env` and fill in. `.env` is gitignored — NEVER commit real keys.
#
# Client-side (safe to ship): only the Supabase URL + anon/publishable key.
# RLS in supabase/schema.sql enforces per-user access, so the anon key is public.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────
# SERVER-ONLY secrets — DO NOT prefix with EXPO_PUBLIC_ and DO NOT put
# in the app bundle. Set these on the edge function instead:
#   supabase secrets set ALADIN_TTB_KEY=... KAKAO_REST_KEY=...
# (Listed here only for documentation.)
# ALADIN_TTB_KEY=
# KAKAO_REST_KEY=
